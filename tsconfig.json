{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "ES2022",
                            "moduleResolution":  "Bundler",
                            "types":  [
                                          "@cloudflare/workers-types",
                                          "node"
                                      ],
                            "lib":  [
                                        "ES2022"
                                    ],
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "forceConsistentCasingInFileNames":  true
                        },
    "include":  [
                    "src"
                ]
}
